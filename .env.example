# Copy to .env and adjust. All values are optional; sensible defaults are used.

# --- Results store ---
# SQLite (default). For Postgres, set e.g.:
# DATABASE_URL=postgresql+psycopg://evalforge:evalforge@localhost:5432/evalforge
EVALFORGE_DATABASE_URL=sqlite:///evalforge.db

# --- Target adapter (the system under test) ---
# One of: mock | openai
EVALFORGE_TARGET=mock
# For target=openai (any OpenAI-compatible chat completions endpoint):
EVALFORGE_TARGET_BASE_URL=https://api.openai.com/v1
EVALFORGE_TARGET_MODEL=gpt-4o-mini
EVALFORGE_TARGET_API_KEY=

# --- Judge (used by the RAG groundedness scorer) ---
# One of: heuristic | llm
EVALFORGE_JUDGE=heuristic
# For judge=llm (any OpenAI-compatible chat completions endpoint):
EVALFORGE_JUDGE_BASE_URL=https://api.openai.com/v1
EVALFORGE_JUDGE_MODEL=gpt-4o-mini
EVALFORGE_JUDGE_API_KEY=

# --- Run metadata ---
EVALFORGE_SUITES_DIR=suites
EVALFORGE_THRESHOLDS_FILE=thresholds.yaml
